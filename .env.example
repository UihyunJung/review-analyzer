# Cloudflare Workers API URL (Claude API 키는 여기에 절대 포함하지 않을 것)
PLASMO_PUBLIC_API_URL=https://place-review-api.your-account.workers.dev

# Supabase (클라이언트용 — Phase 5 인증에서 사용)
PLASMO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PLASMO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Paddle 체크아웃 페이지 URL (GitHub Pages)
PLASMO_PUBLIC_CHECKOUT_URL=https://your-username.github.io/review-analyzer/checkout
