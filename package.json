{
  "name": "review-analyzer",
  "displayName": "Place Review Analyzer",
  "version": "0.2.0",
  "description": "AI-powered restaurant & place review insights for Google Maps",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --config vite.cs-gmaps.config.js",
    "build:dev": "vite build --mode development && vite build --config vite.cs-gmaps.config.js --mode development",
    "lint": "eslint src/",
    "format:check": "prettier --check 'src/**/*.{ts,js}'",
    "format": "prettier --write 'src/**/*.{ts,js}'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.74.0"
  },
  "packageManager": "pnpm@10.5.2"
}
